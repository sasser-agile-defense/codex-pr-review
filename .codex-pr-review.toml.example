# .codex-pr-review.toml — project-level configuration for the codex-pr-review skill.
#
# This file is OPTIONAL. v2 P3 reads the [deterministic] section to wire up
# the lint / typecheck / test floor. Drop this file at your repo root as
# `.codex-pr-review.toml` (no `.example`) to enable.
#
# Allowed keys under [deterministic] (anything else is a hard fail):
#   lint            — command for the project linter (e.g. ruff/eslint/golangci-lint)
#   typecheck       — command for the project typechecker (e.g. tsc/mypy)
#   tests           — command for the project test runner (e.g. pytest)
#   test_files_only — boolean; when true, the runner appends the diff's file
#                     paths to the test command (per-file mode). Skipped if the
#                     test runner doesn't support per-file args.
#
# Command strings are sanitized: only [a-zA-Z0-9 ./_=-] characters are allowed.
# Anything outside that set (`;`, `&`, `|`, `$`, …) hard-fails with an unsafe-
# command error before the tool is invoked.
#
# Auto-detection (no toml): det-floor.sh falls back to `ruff check` if
# pyproject.toml has [tool.ruff], `eslint` if `.eslintrc.*` exists, `golangci-
# lint run` if `.golangci.yml` exists, `tsc --noEmit` if `tsconfig.json` exists.

[deterministic]
# Each command is run with cwd at the repo root. Output is parsed for
# (file, line, message) tuples and converted into [deterministic] findings,
# scoped to lines touched by the PR diff.
lint = "ruff check"
typecheck = "mypy --strict"
tests = "pytest -x --tb=short"
# If true, append the diff's file paths to the test command (per-file mode).
test_files_only = true
